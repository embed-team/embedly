{
  "extends": "@embedly/config/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "noEmit": true,
    "types": ["./worker-configuration.d.ts"],
    "rootDir": "./src"
  },
  "include": ["src/**/*", "*.js", "*.ts"],
  "exclude": ["node_modules"],
  "references": [
    {
      "path": "../../packages/config"
    }
  ]
}
