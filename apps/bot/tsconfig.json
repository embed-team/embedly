{
  "extends": "@embedly/config/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "./types",
    "types": ["node"]
  },
  "include": ["src/**/*", "*.js", "*.ts"],
  "exclude": ["node_modules", "dist", "tsdown.config.ts"],
  "references": [
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/platforms"
    },
    {
      "path": "../api"
    }
  ]
}
